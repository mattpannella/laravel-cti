{
    "name": "pannella/laravel-cti",
    "description": "A Laravel package for Class Table Inheritance support with automatic subtype casting.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/mattpannella/laravel-cti",
    "support": {
        "issues": "https://github.com/mattpannella/laravel-cti/issues",
        "source": "https://github.com/mattpannella/laravel-cti"
    },
    "keywords": [
        "laravel",
        "eloquent",
        "cti",
        "class table inheritance",
        "inheritance",
        "subtype casting",
        "polymorphic",
        "orm",
        "multi-table"
    ],
    "version": "3.5.2",
    "authors": [
        {
            "name": "Matt Pannella",
            "email": "mattpannella@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/database": ">=8.0 <14.0"
    },
    "autoload": {
        "psr-4": {
            "Pannella\\Cti\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pannella\\Cti\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Pannella\\Cti\\CtiServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "require-dev": {
        "phpunit/phpunit": "^9.0 || ^10.0 || ^11.0",
        "illuminate/events": ">=8.0 <14.0",
        "illuminate/container": ">=8.0 <14.0",
        "illuminate/queue": ">=8.0 <14.0",
        "phpstan/phpstan": "^2.1",
        "illuminate/config": ">=8.0 <14.0",
        "illuminate/log": ">=8.0 <14.0"
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
        "test:types": "phpstan --memory-limit=1G"
    }
}
